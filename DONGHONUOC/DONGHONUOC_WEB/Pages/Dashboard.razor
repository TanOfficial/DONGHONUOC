@page "/"
@page "/dashboard"
@using DONGHONUOC_WEB.Models
@using Microsoft.AspNetCore.Components.Authorization
@attribute [Authorize]
@inject HttpClient Http

<PageTitle>Dashboard - Quản Lý Đọc Số</PageTitle>

<div class="mb-4">
    <h3 class="fw-bold text-dark mb-0">Tổng Quan</h3>
    <p class="text-muted small">Chào mừng trở lại hệ thống quản lý.</p>
</div>

<!-- Stats Cards -->
<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="stats-card d-flex align-items-center">
            <div class="stats-icon bg-icon-primary">
                <i class="bi bi-people-fill"></i>
            </div>
            <div>
                <h6 class="text-muted mb-0">Khách Hàng</h6>
                <h4 class="fw-bold mb-0">1,250</h4>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stats-card d-flex align-items-center">
            <div class="stats-icon bg-icon-success">
                <i class="bi bi-check-circle-fill"></i>
            </div>
            <div>
                <h6 class="text-muted mb-0">Đã Đọc (T10)</h6>
                <h4 class="fw-bold mb-0">85%</h4>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stats-card d-flex align-items-center">
            <div class="stats-icon bg-icon-warning">
                <i class="bi bi-exclamation-triangle-fill"></i>
            </div>
            <div>
                <h6 class="text-muted mb-0">Bất Thường</h6>
                <h4 class="fw-bold mb-0">12</h4>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="stats-card d-flex align-items-center">
            <div class="stats-icon text-white bg-primary">
                <i class="bi bi-calendar-check"></i>
            </div>
            <div>
                <h6 class="text-muted mb-0">Kỳ Hiện Tại</h6>
                <h4 class="fw-bold mb-0">10/2023</h4>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-header bg-white py-3 border-bottom">
        <h5 class="mb-0 fw-bold text-primary"><i class="bi bi-list-ul me-2"></i>Danh Sách Kỳ Đọc Số</h5>
    </div>
    <div class="card-body p-0">
        @if (kyDocs == null)
        {
            <div class="text-center py-5">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <p class="mt-2 text-muted">Đang tải dữ liệu...</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-secondary">
                        <tr>
                            <th class="ps-4">Tên Kỳ</th>
                            <th>Tháng/Năm</th>
                            <th>Ngày Bắt Đầu</th>
                            <th>Ngày Kết Thúc</th>
                            <th>Trạng Thái</th>
                            <th class="text-end pe-4">Thao Tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var ky in kyDocs)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-dark">@ky.TenKyDoc</td>
                                <td><span class="badge bg-light text-dark border">@ky.Ky/@ky.Nam</span></td>
                                <td>@ky.NgayBatDau?.ToShortDateString()</td>
                                <td>@ky.NgayKetThuc?.ToShortDateString()</td>
                                <td>
                                    @if (ky.TrangThai)
                                    {
                                        <span class="badge bg-success">Hoạt động</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Đã đóng</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <button class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@code {
    private KyDoc[]? kyDocs;

    protected override async Task OnInitializedAsync()
    {
        try 
        {
            kyDocs = await Http.GetFromJsonAsync<KyDoc[]>("api/DocChiSo/kydoc");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error fetching data: {ex.Message}");
        }
    }
}
