@page "/register"
@layout LoginLayout
@using DONGHONUOC_WEB.Models
@using DONGHONUOC_WEB.Services
@inject AuthService AuthService
@inject NavigationManager Navigation

<PageTitle>Đăng Ký - Hệ Thống</PageTitle>

<div class="login-container">
    <div class="card login-card" style="width: 450px;">
        <div class="login-header">
            <h3 class="mb-1 text-primary fw-bold">ĐĂNG KÝ TÀI KHOẢN</h3>
            <p class="text-muted small mb-0">Hệ thống quản lý dữ liệu nước sạch</p>
        </div>

        <div class="login-body">
            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger d-flex align-items-center" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>
                    <div>@errorMessage</div>
                </div>
            }

            <EditForm Model="@registerModel" OnValidSubmit="HandleRegister">
                <DataAnnotationsValidator />
                
                <div class="form-floating mb-3">
                    <InputText id="floatingUsername" class="form-control" @bind-Value="registerModel.Username" placeholder="Tài khoản" />
                    <label for="floatingUsername">Tài khoản</label>
                    <ValidationMessage For="@(() => registerModel.Username)" />
                </div>

                <div class="form-floating mb-3">
                    <InputText type="password" id="floatingPassword" class="form-control" @bind-Value="registerModel.Password" placeholder="Mật khẩu" />
                    <label for="floatingPassword">Mật khẩu</label>
                    <ValidationMessage For="@(() => registerModel.Password)" />
                </div>

                <div class="form-floating mb-4">
                    <InputText id="floatingName" class="form-control" @bind-Value="registerModel.HoTen" placeholder="Họ và tên" />
                    <label for="floatingName">Họ và tên</label>
                    <ValidationMessage For="@(() => registerModel.HoTen)" />
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2 fw-bold text-uppercase mb-3" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                        <span>Đang đăng ký...</span>
                    }
                    else
                    {
                        <span><i class="bi bi-person-plus-fill me-2"></i>Đăng Ký</span>
                    }
                </button>

                <div class="text-center">
                    <a href="login" class="text-decoration-none">Đã có tài khoản? Đăng nhập</a>
                </div>
            </EditForm>
        </div>
        <div class="card-footer bg-transparent text-center py-3 border-0">
            <small class="text-muted">Designed for DongHoNuoc System &copy; 2026</small>
        </div>
    </div>
</div>

@code {
    private RegisterRequest registerModel = new();
    private string? errorMessage;
    private bool isLoading = false;

    private async Task HandleRegister()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            await Task.Delay(500); // Simulate network latency

            var result = await AuthService.Register(registerModel);
            if (result.Success)
            {
                // Navigate back to login with success msg (simplest way is just redirect)
                Navigation.NavigateTo("login");
            }
            else
            {
                errorMessage = result.Message;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Lỗi hệ thống: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }
}
