<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand fw-bold" href="">
            <i class="bi bi-droplet-fill me-2"></i>ĐỒNG HỒ NƯỚC
        </a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="nav flex-column pt-3">
        <AuthorizeView>
            <Authorized>
                <div class="nav-item px-3 mb-2">
                    <NavLink class="nav-link rounded-3" href="dashboard" Match="NavLinkMatch.All">
                        <i class="bi bi-speedometer2 me-3 fs-5"></i> Dashboard
                    </NavLink>
                </div>
                <!-- Future Modules
                <div class="nav-item px-3 mb-2">
                    <NavLink class="nav-link rounded-3" href="billing-periods">
                        <i class="bi bi-calendar-week me-3 fs-5"></i> Kỳ Đọc Số
                    </NavLink>
                </div>
                -->
            </Authorized>
        </AuthorizeView>
        
        <div class="nav-item px-3 mb-2">
            <NavLink class="nav-link rounded-3" href="counter">
                <i class="bi bi-plus-square me-3 fs-5"></i> Counter (Demo)
            </NavLink>
        </div>
        <div class="nav-item px-3 mb-2">
            <NavLink class="nav-link rounded-3" href="weather">
                <i class="bi bi-cloud-sun me-3 fs-5"></i> Weather (Demo)
            </NavLink>
        </div>
    </nav>
</div>

@code {
    private bool collapseNavMenu = true;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }
}
